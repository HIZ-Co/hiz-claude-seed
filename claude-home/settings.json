{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Bash(python:*)",
      "Bash(pip:*)",
      "Bash(curl:*)",
      "Bash(ls:*)",
      "Bash(dir:*)",
      "Bash(cd:*)",
      "Bash(cat:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(echo:*)",
      "Bash(powershell:*)"
    ],
    "defaultMode": "acceptEdits"
  },
  "model": "opus",
  "theme": "light",
  "autoUpdatesChannel": "latest",
  "syntaxHighlightingDisabled": true
}
